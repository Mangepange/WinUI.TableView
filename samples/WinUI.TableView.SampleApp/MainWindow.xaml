<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="WinUI.TableView.SampleApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:WinUI.TableView.SampleApp"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="WinUI.TableView.SampleApp"
        mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Loaded="RootGridLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar"
                  Title="WinUI.TableView.SampleApp"
                  BackRequested="OnBackRequested"
                  IsBackButtonVisible="{x:Bind rootFrame.CanGoBack, Mode=OneWay}"
                  IsPaneToggleButtonVisible="True"
                  PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/TableView.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView x:Name="navigationView"
                        Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        SelectionChanged="OnNavigationSelectionChanged"
                        IsEnabled="{Binding Visibility, ElementName=loadingIndicator, Converter={StaticResource VisibilityToBool}}">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Overview"
                                    x:Name="overViewNavItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />

                <NavigationViewItem Content="Grid Lines">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Selection">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE73A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Corner Button">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B0;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Alternate Row Color">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8C0;"
                                  RenderTransformOrigin="0.5,0.5">
                            <FontIcon.RenderTransform>
                                <RotateTransform Angle="-90" />
                            </FontIcon.RenderTransform>
                        </FontIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Context Flyouts">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A4;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Row Reorder">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEC8F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Pagination">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE89A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Editing">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE70F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Sorting">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE84F;"
                                  RenderTransformOrigin="0.5,0.5">
                            <FontIcon.RenderTransform>
                                <RotateTransform Angle="-90" />
                            </FontIcon.RenderTransform>
                        </FontIcon>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Custom Sorting" />
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
                <NavigationViewItem Content="Filtering">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71C;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Customize Filter Flyout" />
                        <NavigationViewItem Content="External Filtering" />
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
                <NavigationViewItem Content="Clipboard Actions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8C8;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Data Export">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDE1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Large Dataset">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE92D;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Conditional Cell Styling">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE794;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Column Sizing">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xED5E;"
                                  RenderTransformOrigin="0.5,0.5">
                            <FontIcon.RenderTransform>
                                <RotateTransform Angle="90" />
                            </FontIcon.RenderTransform>
                        </FontIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Customization">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE771;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.Content>
                <Grid>
                    <Frame x:Name="rootFrame"
                           CacheSize="0"
                           IsNavigationStackEnabled="True"
                           Navigated="OnRootFrameNavigated"
                           IsEnabled="{Binding Visibility, ElementName=loadingIndicator, Converter={StaticResource VisibilityToBool}}" />
                    <StackPanel x:Name="loadingIndicator"
                                Spacing="16"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <ProgressRing IsActive="True"
                                      Width="50"
                                      Height="50" />
                        <TextBlock Text="Preparing demo data..."
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Window>
